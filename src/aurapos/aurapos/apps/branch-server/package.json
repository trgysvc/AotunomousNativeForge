// apps/branch-server/package.json
{
  "name": "branch-server",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "fastify": "^4.24.0",
    "fastify-cors": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
